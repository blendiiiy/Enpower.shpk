# MySQL / phpMyAdmin - për formën e kontaktit dhe rezervimin e takimeve
# 1. Krijo databazën "En-power.shpk" (ose emër tjetër) në phpMyAdmin
# 2. Ekzekuto SQL nga database/schema.sql
# 3. Vendos këto variabla:

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=En-power.shpk

# Të dhënat e kontaktit që shfaqen në faqen /contact (opsional; pa këto përdoren vlerat e parazgjedhura)
CONTACT_PAGE_EMAIL=enpower@gmail.com
CONTACT_PAGE_PHONE=+383 44 222 836
CONTACT_PAGE_ADDRESS=Kline, Kosovë

# Email (Resend) – njoftim te ti + konfirmim te klienti
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=
RESEND_FROM_EMAIL=onboarding@resend.dev
